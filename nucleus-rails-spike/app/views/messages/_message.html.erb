<%# Rendered both server-side on page load and via Action Cable broadcast
    from Message#after_create_commit. Broadcasts run without a controller
    context, so we can't use current_clerk_user here — the "mine vs theirs"
    styling is deferred to Rs9 (Portal), which has proper client auth. %>
<div id="<%= dom_id(message) %>" class="flex justify-start">
  <div class="max-w-[75%] rounded-2xl px-3 py-2 text-sm bg-white border text-gray-800">
    <div class="whitespace-pre-wrap"><%= message.body %></div>
    <div class="mt-0.5 text-[10px] text-gray-400">
      <%= message.sender_clerk_id.to_s.last(6) %> · <%= l(message.created_at, format: :short) %>
    </div>
  </div>
</div>

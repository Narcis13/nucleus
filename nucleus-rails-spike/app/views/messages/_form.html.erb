<%= form_with(model: [ conversation, message ],
              id: "new_message_#{conversation.id}",
              class: "mt-3 flex gap-2") do |f| %>
  <%= f.text_field :body,
                   autofocus: true,
                   required: true,
                   placeholder: "Write a message…",
                   class: "flex-1 rounded border px-3 py-2 text-sm" %>
  <%= f.submit "Send", class: "rounded bg-gray-900 text-white px-4 py-2 text-sm" %>
<% end %>

<% content_for :title, "Conversations" %>

<div class="max-w-3xl mx-auto p-6 w-full">
  <h1 class="text-2xl font-semibold mb-6">Conversations</h1>

  <% if @conversations.any? %>
    <ul class="divide-y rounded border">
      <% @conversations.each do |conv| %>
        <li class="p-3 flex justify-between items-center">
          <%= link_to conv.client.full_name, conversation_path(conv), class: "text-blue-600" %>
          <span class="text-xs text-gray-500"><%= time_ago_in_words(conv.updated_at) %> ago</span>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="text-gray-500 mb-4">No conversations yet. Start one from a client.</p>
  <% end %>

  <% if Client.any? %>
    <div class="mt-6 border-t pt-6">
      <h2 class="text-sm font-medium text-gray-700 mb-2">Start a conversation</h2>
      <ul class="space-y-1">
        <% Client.order(:full_name).each do |client| %>
          <li>
            <%= button_to client.full_name,
                          conversations_path(client_id: client.id),
                          method: :post,
                          class: "text-sm text-blue-600 hover:underline" %>
          </li>
        <% end %>
      </ul>
    </div>
  <% end %>
</div>

<% content_for :title, @client.full_name %>

<div class="max-w-xl mx-auto p-6">
  <%= link_to "< Back", clients_path, class: "text-sm text-gray-500" %>
  <h1 class="text-2xl font-semibold mt-2"><%= @client.full_name %></h1>
  <dl class="mt-4 text-sm space-y-1">
    <div><dt class="inline text-gray-500">Email:</dt> <dd class="inline"><%= @client.email %></dd></div>
    <div><dt class="inline text-gray-500">Phone:</dt> <dd class="inline"><%= @client.phone %></dd></div>
    <div><dt class="inline text-gray-500">Professional:</dt> <dd class="inline"><%= @client.professional_id %></dd></div>
  </dl>
</div>

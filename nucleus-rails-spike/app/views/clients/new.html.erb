<% content_for :title, "New client" %>

<div class="max-w-xl mx-auto p-6">
  <h1 class="text-2xl font-semibold mb-6">New client</h1>

  <%= form_with model: @client, class: "space-y-4" do |f| %>
    <% if @client.errors.any? %>
      <div class="rounded border border-red-300 bg-red-50 p-3 text-red-700">
        <ul class="list-disc pl-5">
          <% @client.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= f.label :full_name, class: "block text-sm font-medium mb-1" %>
      <%= f.text_field :full_name, class: "w-full border rounded px-3 py-2" %>
    </div>

    <div>
      <%= f.label :email, class: "block text-sm font-medium mb-1" %>
      <%= f.email_field :email, class: "w-full border rounded px-3 py-2" %>
    </div>

    <div>
      <%= f.label :phone, class: "block text-sm font-medium mb-1" %>
      <%= f.text_field :phone, class: "w-full border rounded px-3 py-2" %>
    </div>

    <div class="flex gap-2">
      <%= f.submit "Create", class: "rounded bg-gray-900 text-white px-3 py-1.5" %>
      <%= link_to "Cancel", clients_path, class: "rounded border px-3 py-1.5" %>
    </div>
  <% end %>
</div>

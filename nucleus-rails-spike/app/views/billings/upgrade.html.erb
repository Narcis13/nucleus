<div class="max-w-xl mx-auto py-16 px-6 text-center">
  <h1 class="text-3xl font-bold mb-3">Plan limit reached</h1>
  <p class="text-gray-700 mb-6">
    <% if flash[:alert].present? %>
      <%= flash[:alert] %>
    <% else %>
      Your current plan does not allow creating more clients. Upgrade to continue.
    <% end %>
  </p>
  <%= link_to "Choose a plan", billing_path,
              class: "inline-block px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700" %>
</div>

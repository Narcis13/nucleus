<div class="max-w-2xl mx-auto py-12 px-6">
  <h1 class="text-3xl font-bold mb-6">Billing</h1>

  <% if flash[:notice].present? %>
    <div class="mb-4 px-3 py-2 bg-green-50 text-green-800 rounded"><%= flash[:notice] %></div>
  <% end %>
  <% if flash[:alert].present? %>
    <div class="mb-4 px-3 py-2 bg-amber-50 text-amber-800 rounded"><%= flash[:alert] %></div>
  <% end %>

  <section class="border rounded p-4 mb-8">
    <div class="flex items-baseline justify-between mb-3">
      <h2 class="text-lg font-semibold">Current plan</h2>
      <span class="text-sm uppercase tracking-wide text-gray-500"><%= Plans.label_for(@plan_id) %></span>
    </div>

    <% if @subscription&.active? %>
      <p class="text-sm text-gray-700 mb-1">Status: <strong><%= @subscription.status %></strong></p>
      <p class="text-sm text-gray-700 mb-1">Renews: <%= @subscription.current_period_end&.to_date %></p>
    <% else %>
      <p class="text-sm text-gray-700">You are not currently subscribed.</p>
    <% end %>

    <p class="text-sm text-gray-700 mt-3">
      Clients: <strong><%= @client_count %></strong><% if @max_clients %> of <%= @max_clients %><% end %>
    </p>
  </section>

  <section class="border rounded p-4 mb-8">
    <h2 class="text-lg font-semibold mb-3">Change plan</h2>
    <div class="grid sm:grid-cols-3 gap-3">
      <% Plans.all.each do |id, cfg| %>
        <%= button_to billing_checkout_path(plan: id),
                      method: :post,
                      class: "border rounded p-3 text-left hover:bg-gray-50 w-full",
                      disabled: cfg[:stripe_price_id].blank? do %>
          <div class="font-semibold"><%= cfg[:label] %></div>
          <div class="text-xs text-gray-500">up to <%= cfg[:max_clients] %> clients</div>
          <% if cfg[:stripe_price_id].blank? %>
            <div class="text-xs text-red-500 mt-1">STRIPE_<%= id.upcase %>_PRICE missing</div>
          <% end %>
        <% end %>
      <% end %>
    </div>
  </section>

  <section class="border rounded p-4">
    <h2 class="text-lg font-semibold mb-3">Manage subscription</h2>
    <%= button_to "Open Customer Portal", billing_portal_path,
                  method: :post,
                  class: "px-3 py-2 bg-gray-900 text-white rounded hover:bg-black" %>
    <p class="text-xs text-gray-500 mt-2">
      Update payment method, invoices, or cancel from Stripe's hosted portal.
    </p>
  </section>

  <div class="mt-8 text-sm">
    <%= link_to "← Dashboard", dashboard_path, class: "text-blue-600 hover:underline" %>
  </div>
</div>

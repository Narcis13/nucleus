# ==============================================================================
# Core-Pro — Local environment variable template
# Copy to `.env.local` and fill in values. All values are validated at build
# time by `lib/env.ts` (@t3-oss/env-nextjs). Missing required vars fail the
# build — this is by design.
# ==============================================================================

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=CorePro

# ── Clerk (auth) ─────────────────────────────────────────────────────────────
# Native Supabase Third-Party Auth integration — no JWT templates needed.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ── Supabase ─────────────────────────────────────────────────────────────────
# Public Supabase URL + anon key are used client-side for Realtime/Storage.
# Service-role key is server-only (admin operations + webhooks).
# DATABASE_URL is the direct Postgres connection used by drizzle-kit for
# migrations. When using Supabase cloud, use the `session` pooler URL.
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# ── Stripe ───────────────────────────────────────────────────────────────────
# Stripe v22 requires `new Stripe(secret, { apiVersion: '2026-01-01.acacia' })`.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_GROWTH_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...

# ── Resend (transactional email) ─────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@corepro.com

# ── Trigger.dev v4 (background jobs) ─────────────────────────────────────────
# v3 deploys shut off 2026-04-01 — always deploy against v4.
TRIGGER_SECRET_KEY=tr_dev_...
TRIGGER_API_URL=https://api.trigger.dev

# ── Sentry (observability) ───────────────────────────────────────────────────
# Public DSN goes to browser; auth token + org/project are build-time only.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# ── Upstash (rate limiting + ephemeral cache) ────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── PostHog (analytics + feature flags) ──────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ── Optional integrations ────────────────────────────────────────────────────
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=

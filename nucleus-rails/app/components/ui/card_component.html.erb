<%= tag.div class: classes, **@html do %>
  <% if header? || title.present? %>
    <div class="px-5 py-3 border-b border-border">
      <% if header? %>
        <%= header %>
      <% else %>
        <h3 class="font-medium"><%= title %></h3>
        <% if subtitle.present? %>
          <p class="text-sm text-fg-muted"><%= subtitle %></p>
        <% end %>
      <% end %>
    </div>
  <% end %>

  <div class="<%= body_padding %>">
    <%= content %>
  </div>

  <% if footer? %>
    <div class="px-5 py-3 border-t border-border bg-surface-2 rounded-b-lg">
      <%= footer %>
    </div>
  <% end %>
<% end %>

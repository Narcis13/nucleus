<div class="<%= classes %>"
     role="status"
     data-controller="toast"
     data-toast-dismiss-after-value="<%= dismiss_after %>">
  <div class="flex-1 min-w-0">
    <% if title.present? %>
      <div class="font-medium text-fg"><%= title %></div>
    <% end %>
    <div class="text-fg/90"><%= message %></div>
  </div>
  <button type="button"
          data-action="toast#dismiss"
          class="text-current/70 hover:text-current"
          aria-label="Dismiss">×</button>
</div>

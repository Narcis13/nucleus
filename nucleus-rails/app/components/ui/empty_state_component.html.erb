<div class="flex flex-col items-center justify-center text-center rounded-lg border border-dashed border-border bg-surface-2/50 px-6 py-12">
  <% if icon.present? %>
    <div class="mb-3 text-3xl text-fg-muted" aria-hidden="true"><%= icon %></div>
  <% end %>
  <h3 class="text-base font-semibold text-fg"><%= title %></h3>
  <% if description.present? %>
    <p class="mt-1 max-w-sm text-sm text-fg-muted"><%= description %></p>
  <% end %>
  <% if action? %>
    <div class="mt-4"><%= action %></div>
  <% end %>
</div>

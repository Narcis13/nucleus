<div class="max-w-md mx-auto py-16 px-6">
  <h1 class="text-2xl font-bold mb-6">Sign in</h1>
  <div id="clerk-sign-in"></div>

  <% if clerk_js_url %>
    <script async crossorigin="anonymous"
            data-clerk-publishable-key="<%= ENV['CLERK_PUBLISHABLE_KEY'] %>"
            src="<%= clerk_js_url %>"
            type="text/javascript"></script>
    <script>
      window.addEventListener("load", async () => {
        if (typeof Clerk === "undefined") return;
        await Clerk.load();
        const el = document.getElementById("clerk-sign-in");
        if (el) Clerk.mountSignIn(el, { afterSignInUrl: "<%= dashboard_path %>", afterSignUpUrl: "<%= dashboard_path %>" });
      });
    </script>
  <% else %>
    <p class="text-sm text-red-600">Clerk is not configured. Set CLERK_PUBLISHABLE_KEY.</p>
  <% end %>
</div>

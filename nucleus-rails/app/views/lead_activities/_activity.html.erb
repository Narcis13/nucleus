<li id="<%= dom_id(activity) %>"
    class="flex items-start gap-2 rounded-md border border-border bg-surface p-2 text-xs">
  <span class="mt-0.5 shrink-0 text-fg-muted">◷</span>
  <div class="min-w-0 flex-1">
    <div class="flex items-center justify-between gap-2">
      <span class="inline-flex items-center rounded-full border border-border px-1.5 py-0.5 text-[10px] capitalize">
        <%= activity.activity_type.to_s.tr("_", " ") %>
      </span>
      <span class="text-[10px] text-fg-muted">
        <%= activity.created_at.strftime("%b %-d, %Y · %-I:%M %p") %>
      </span>
    </div>
    <% if activity.description.present? %>
      <p class="mt-1"><%= activity.description %></p>
    <% end %>
  </div>
</li>

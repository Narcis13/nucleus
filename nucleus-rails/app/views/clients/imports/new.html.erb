<% content_for :page_title, "Import clients" %>

<div class="space-y-6 max-w-3xl">
  <header>
    <h1 class="text-2xl font-semibold">Import clients</h1>
    <p class="text-sm text-fg-muted">Upload a CSV with columns: full_name, email, phone, status, source, notes.</p>
  </header>

  <%= render Ui::CardComponent.new(title: "Upload") do %>
    <%= form_with url: import_clients_path, multipart: true, local: true, class: "space-y-4" do |f| %>
      <div class="flex flex-col gap-1">
        <%= label_tag :file, "CSV file", class: "text-xs text-fg-muted" %>
        <%= file_field_tag :file, accept: "text/csv,.csv", required: true, class: "text-sm" %>
      </div>
      <%= f.submit "Preview", class: "inline-flex items-center justify-center h-10 px-4 rounded-md bg-primary text-on-primary text-sm font-medium" %>
    <% end %>
  <% end %>
</div>

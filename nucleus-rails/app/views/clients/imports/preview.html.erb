<% content_for :page_title, "Import preview" %>

<div class="space-y-6 max-w-5xl">
  <header>
    <h1 class="text-2xl font-semibold">Import preview</h1>
    <p class="text-sm text-fg-muted">
      <%= @report.valid_count %> valid row<%= "s" unless @report.valid_count == 1 %>,
      <%= @report.invalid_count %> invalid.
    </p>
  </header>

  <%= render Ui::CardComponent.new(title: "Rows") do %>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead class="bg-surface-2 text-left text-xs uppercase tracking-wide text-fg-muted">
          <tr>
            <th class="px-3 py-2">#</th>
            <th class="px-3 py-2">Full name</th>
            <th class="px-3 py-2">Email</th>
            <th class="px-3 py-2">Status</th>
            <th class="px-3 py-2">Errors</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-border">
          <% @report.rows.each do |row| %>
            <tr class="<%= row.valid? ? "" : "bg-danger/5" %>">
              <td class="px-3 py-2 text-fg-muted"><%= row.index %></td>
              <td class="px-3 py-2"><%= row.attrs["full_name"] %></td>
              <td class="px-3 py-2"><%= row.attrs["email"] %></td>
              <td class="px-3 py-2"><%= row.attrs["status"] %></td>
              <td class="px-3 py-2 text-xs text-danger">
                <% if row.errors.present? %>
                  <%= row.errors.map { |field, msgs| "#{field}: #{Array(msgs).join(", ")}" }.join("; ") %>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>

  <div class="flex gap-3">
    <%= button_to "Confirm import (#{@report.valid_count} rows)",
          import_commit_clients_path, method: :post,
          class: "inline-flex items-center justify-center h-10 px-4 rounded-md bg-primary text-on-primary text-sm font-medium" %>
    <%= link_to "Cancel", import_new_clients_path,
          class: "inline-flex items-center justify-center h-10 px-4 rounded-md border border-border text-sm" %>
  </div>
</div>

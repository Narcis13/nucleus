<%= turbo_frame_tag "tab_activity" do %>
  <%= render Ui::CardComponent.new(title: "Recent activity") do %>
    <% if audit_logs.any? %>
      <ul class="divide-y divide-border">
        <% audit_logs.each do |log| %>
          <li class="py-2 text-sm flex items-start gap-3">
            <span class="text-xs text-fg-muted w-32 shrink-0"><%= log.created_at.strftime("%Y-%m-%d %H:%M") %></span>
            <div>
              <span class="font-medium"><%= log.action.titleize %></span>
              <% if log.audited_changes.any? %>
                <span class="text-xs text-fg-muted">· <%= log.audited_changes.keys.join(", ") %></span>
              <% end %>
            </div>
          </li>
        <% end %>
      </ul>
    <% else %>
      <%= render Ui::EmptyStateComponent.new(title: "No activity yet", description: "Changes to this client will appear here.") %>
    <% end %>
  <% end %>
<% end %>

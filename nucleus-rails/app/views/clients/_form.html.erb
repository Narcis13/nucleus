<%= form_with model: client, local: true, class: "space-y-4 max-w-2xl" do |f| %>
  <% if client.errors.any? %>
    <div class="rounded-md border border-danger/40 bg-danger/10 p-3 text-sm text-danger">
      <ul class="list-disc pl-4">
        <% client.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid gap-4 md:grid-cols-2">
    <div class="flex flex-col gap-1">
      <%= f.label :full_name, class: "text-xs text-fg-muted" %>
      <%= f.text_field :full_name, required: true, class: "h-9 rounded-md border border-border bg-surface px-3 text-sm" %>
    </div>
    <div class="flex flex-col gap-1">
      <%= f.label :email, class: "text-xs text-fg-muted" %>
      <%= f.email_field :email, class: "h-9 rounded-md border border-border bg-surface px-3 text-sm" %>
    </div>
    <div class="flex flex-col gap-1">
      <%= f.label :phone, class: "text-xs text-fg-muted" %>
      <%= f.telephone_field :phone, class: "h-9 rounded-md border border-border bg-surface px-3 text-sm" %>
    </div>
    <div class="flex flex-col gap-1">
      <%= f.label :status, class: "text-xs text-fg-muted" %>
      <%= f.select :status, Client::STATUSES.map { |s| [ s.titleize, s ] }, {}, class: "h-9 rounded-md border border-border bg-surface px-3 text-sm" %>
    </div>
    <div class="flex flex-col gap-1">
      <%= f.label :source, class: "text-xs text-fg-muted" %>
      <%= f.text_field :source, class: "h-9 rounded-md border border-border bg-surface px-3 text-sm" %>
    </div>
  </div>

  <div class="flex flex-col gap-1">
    <%= f.label :notes, "Notes (Overview)", class: "text-xs text-fg-muted" %>
    <%= f.text_area :notes, rows: 5, class: "rounded-md border border-border bg-surface px-3 py-2 text-sm" %>
  </div>

  <div class="flex gap-3">
    <%= f.submit class: "inline-flex items-center justify-center h-10 px-4 rounded-md bg-primary text-on-primary text-sm font-medium" %>
    <%= link_to "Cancel", client.persisted? ? client_path(client) : clients_path,
          class: "inline-flex items-center justify-center h-10 px-4 rounded-md border border-border text-sm" %>
  </div>
<% end %>

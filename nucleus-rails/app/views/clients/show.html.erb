<% content_for :page_title, @client.full_name %>

<div class="space-y-6 max-w-5xl">
  <header class="flex items-start justify-between gap-4">
    <div class="space-y-1">
      <h1 class="text-2xl font-semibold"><%= @client.full_name %></h1>
      <div class="flex items-center gap-2 text-sm text-fg-muted">
        <%= render(Ui::BadgeComponent.new(variant: status_variant(@client.status))) { @client.status.titleize } %>
        <% if @client.email.present? %><span>· <%= @client.email %></span><% end %>
        <% if @client.phone.present? %><span>· <%= @client.phone %></span><% end %>
        <% if @client.source.present? %><span>· <%= @client.source %></span><% end %>
      </div>
      <div class="flex flex-wrap gap-1 pt-1">
        <% @client.tags.each do |tag| %>
          <span class="inline-flex items-center gap-1 rounded-full px-2 py-0.5 text-xs" style="background-color: <%= tag.color %>20; color: <%= tag.color %>; border: 1px solid <%= tag.color %>40;">
            <%= tag.name %>
            <%= button_to "×", client_tag_path(client_id: @client.id, id: tag.id), method: :delete,
                  class: "ml-1 text-xs hover:opacity-70",
                  form: { class: "inline", data: { turbo_confirm: "Remove tag \"#{tag.name}\"?" } } %>
          </span>
        <% end %>
        <%= form_with url: client_tags_path(client_id: @client.id), method: :post, class: "inline-flex items-center gap-1" do |f| %>
          <%= f.select :tag_id, (@tags - @client.tags).map { |t| [ t.name, t.id ] },
                { include_blank: "+ Add tag" },
                onchange: "this.form.requestSubmit()", class: "h-7 rounded-md border border-border bg-surface px-2 text-xs" %>
        <% end %>
      </div>
    </div>
    <div class="flex items-center gap-2">
      <%= link_to "Edit", edit_client_path(@client),
            class: "inline-flex items-center justify-center h-9 px-4 rounded-md border border-border text-sm" %>
      <%= button_to "Delete", client_path(@client), method: :delete,
            data: { turbo_confirm: "Delete #{@client.full_name}?" },
            class: "inline-flex items-center justify-center h-9 px-4 rounded-md border border-danger/40 text-danger text-sm" %>
    </div>
  </header>

  <nav class="border-b border-border flex items-center gap-4 text-sm">
    <% [ :overview, :notes, :documents, :messages, :activity ].each do |tab| %>
      <% current = (params[:tab].presence || "overview") == tab.to_s %>
      <%= link_to tab.to_s.titleize, client_path(@client, tab: tab),
            class: "py-2 border-b-2 #{current ? "border-primary text-fg" : "border-transparent text-fg-muted hover:text-fg"}" %>
    <% end %>
  </nav>

  <%# One Turbo frame per tab. Overview is rendered inline so a user who
      lands on /clients/:id sees data instantly; the other tabs lazy-load
      the corresponding partial when selected. The Rs5 plan calls out
      "one turbo frame per tab — lazy-loaded" and this is the contract. %>
  <% active_tab = (params[:tab].presence || "overview").to_sym %>

  <% if active_tab == :overview %>
    <%= turbo_frame_tag "tab_overview" do %>
      <%= render "overview", client: @client %>
    <% end %>
  <% elsif active_tab == :notes %>
    <%= turbo_frame_tag "tab_notes", src: client_path(@client, tab: :notes, frame: 1) do %>
      <p class="text-sm text-fg-muted">Loading notes…</p>
    <% end %>
  <% elsif active_tab == :documents %>
    <%= turbo_frame_tag "tab_documents", src: client_path(@client, tab: :documents, frame: 1) do %>
      <p class="text-sm text-fg-muted">Loading documents…</p>
    <% end %>
  <% elsif active_tab == :messages %>
    <%= turbo_frame_tag "tab_messages", src: client_path(@client, tab: :messages, frame: 1) do %>
      <p class="text-sm text-fg-muted">Loading messages…</p>
    <% end %>
  <% elsif active_tab == :activity %>
    <%= turbo_frame_tag "tab_activity", src: client_path(@client, tab: :activity, frame: 1) do %>
      <p class="text-sm text-fg-muted">Loading activity…</p>
    <% end %>
  <% end %>
</div>

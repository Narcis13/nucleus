<% content_for :page_title, "Clients" %>

<div class="space-y-6 max-w-7xl">
  <header class="flex items-start justify-between gap-4">
    <div>
      <h1 class="text-2xl font-semibold">Clients</h1>
      <p class="text-sm text-fg-muted">Lead, active, and archived customers for <%= Current.organization&.name %>.</p>
    </div>
    <div class="flex items-center gap-2">
      <%= link_to "Import CSV", import_new_clients_path,
            class: "inline-flex items-center justify-center h-10 px-4 rounded-md border border-border text-sm" %>
      <%= link_to "Export CSV", export_clients_path(q: params[:q]),
            class: "inline-flex items-center justify-center h-10 px-4 rounded-md border border-border text-sm" %>
      <%= link_to "New client", new_client_path,
            class: "inline-flex items-center justify-center h-10 px-4 rounded-md bg-primary text-on-primary text-sm font-medium" %>
    </div>
  </header>

  <%= search_form_for @q, url: clients_path, html: { class: "flex flex-wrap gap-3 items-end" } do |f| %>
    <div class="flex flex-col gap-1">
      <%= f.label :full_name_or_email_cont, "Search", class: "text-xs text-fg-muted" %>
      <%= f.search_field :full_name_or_email_cont, class: "h-9 rounded-md border border-border bg-surface px-3 text-sm", placeholder: "Name or email" %>
    </div>
    <div class="flex flex-col gap-1">
      <%= f.label :status_eq, "Status", class: "text-xs text-fg-muted" %>
      <%= f.select :status_eq, Client::STATUSES.map { |s| [ s.titleize, s ] }, { include_blank: "Any" }, class: "h-9 rounded-md border border-border bg-surface px-3 text-sm" %>
    </div>
    <div class="flex flex-col gap-1">
      <%= f.label :source_eq, "Source", class: "text-xs text-fg-muted" %>
      <%= f.text_field :source_eq, class: "h-9 rounded-md border border-border bg-surface px-3 text-sm" %>
    </div>
    <div class="flex flex-col gap-1">
      <%= f.label :tags_id_in, "Tag", class: "text-xs text-fg-muted" %>
      <%= f.select :tags_id_in, @tags.map { |t| [ t.name, t.id ] }, { include_blank: "Any" }, class: "h-9 rounded-md border border-border bg-surface px-3 text-sm" %>
    </div>
    <div class="flex gap-2">
      <%= f.submit "Apply", class: "inline-flex items-center justify-center h-9 px-4 rounded-md bg-primary text-on-primary text-sm" %>
      <%= link_to "Reset", clients_path,
            class: "inline-flex items-center justify-center h-9 px-4 rounded-md border border-border text-sm" %>
    </div>
  <% end %>

  <%= form_with url: bulk_destroy_clients_path, method: :post,
                data: { controller: "bulk-selection", turbo_confirm: "Delete selected clients?" },
                class: "space-y-2" do |form| %>
    <div class="flex items-center gap-3">
      <%= form.submit "Delete selected", class: "inline-flex items-center justify-center h-9 px-4 rounded-md border border-border text-sm disabled:opacity-40", data: { bulk_selection_target: "submit" }, disabled: true %>
      <span class="text-xs text-fg-muted" data-bulk-selection-target="counter">0 selected</span>
    </div>

    <div class="rounded-lg border border-border bg-surface overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="bg-surface-2 text-left text-xs uppercase tracking-wide text-fg-muted">
            <tr>
              <th class="px-4 py-2 w-10">
                <input type="checkbox" data-bulk-selection-target="selectAll" data-action="bulk-selection#toggleAll" aria-label="Select all">
              </th>
              <th class="px-4 py-2 font-medium"><%= sort_link(@q, :full_name, "Name", default_order: :asc) %></th>
              <th class="px-4 py-2 font-medium"><%= sort_link(@q, :email, "Email", default_order: :asc) %></th>
              <th class="px-4 py-2 font-medium"><%= sort_link(@q, :status, "Status", default_order: :asc) %></th>
              <th class="px-4 py-2 font-medium">Tags</th>
              <th class="px-4 py-2 font-medium"><%= sort_link(@q, :created_at, "Added", default_order: :desc) %></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-border">
            <% @clients.each do |client| %>
              <tr class="hover:bg-surface-2/60">
                <td class="px-4 py-2">
                  <%= check_box_tag "client_ids[]", client.id, false,
                        data: { bulk_selection_target: "row", action: "bulk-selection#toggle" },
                        aria: { label: "Select #{client.full_name}" } %>
                </td>
                <td class="px-4 py-2">
                  <%= link_to client.full_name, client_path(client), class: "font-medium hover:underline" %>
                </td>
                <td class="px-4 py-2 text-fg-muted"><%= client.email %></td>
                <td class="px-4 py-2">
                  <%= render Ui::BadgeComponent.new(variant: status_variant(client.status)) { client.status.titleize } %>
                </td>
                <td class="px-4 py-2">
                  <% client.tags.each do |tag| %>
                    <span class="inline-flex items-center gap-1 rounded-full px-2 py-0.5 text-xs" style="background-color: <%= tag.color %>20; color: <%= tag.color %>; border: 1px solid <%= tag.color %>40;">
                      <%= tag.name %>
                    </span>
                  <% end %>
                </td>
                <td class="px-4 py-2 text-fg-muted text-xs"><%= time_ago_in_words(client.created_at) %> ago</td>
              </tr>
            <% end %>
            <% if @clients.empty? %>
              <tr><td colspan="6" class="p-8 text-center text-fg-muted">
                <%= render Ui::EmptyStateComponent.new(
                      title: "No clients yet",
                      description: "Create one, or import a CSV.") %>
              </td></tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <% if @pagy.pages > 1 %>
        <div class="flex items-center justify-between gap-3 px-4 py-2 border-t border-border text-sm text-fg-muted">
          <span><%= pagy_info(@pagy) %></span>
          <span class="pagy"><%== pagy_nav(@pagy) %></span>
        </div>
      <% end %>
    </div>
  <% end %>
</div>

<% content_for :page_title, "Dashboard" %>

<div class="space-y-6 max-w-4xl">
  <header class="flex items-start justify-between gap-4">
    <div>
      <h1 class="text-2xl font-semibold">Welcome back</h1>
      <p class="text-sm text-fg-muted">Signed in as <%= current_professional.email %>.</p>
    </div>
    <%= render(Ui::BadgeComponent.new(variant: :primary)) { current_professional.role.to_s.titleize } %>
  </header>

  <div class="grid gap-4 md:grid-cols-2">
    <%= render Ui::CardComponent.new(title: "Account", subtitle: "Your Clerk identity") do %>
      <dl class="text-sm space-y-2">
        <div>
          <dt class="text-fg-muted">Email</dt>
          <dd><%= current_professional.email %></dd>
        </div>
        <div>
          <dt class="text-fg-muted">Clerk user id</dt>
          <dd class="font-mono text-xs break-all"><%= current_professional.clerk_user_id %></dd>
        </div>
        <div>
          <dt class="text-fg-muted">Clerk org id</dt>
          <dd class="font-mono text-xs break-all"><%= current_professional.clerk_org_id.presence || "—" %></dd>
        </div>
      </dl>
    <% end %>

    <%= render Ui::CardComponent.new(title: "Workspace", subtitle: "Active organization") do %>
      <% if Current.organization %>
        <dl class="text-sm space-y-2">
          <div>
            <dt class="text-fg-muted">Name</dt>
            <dd><%= Current.organization.name %></dd>
          </div>
          <div>
            <dt class="text-fg-muted">Role</dt>
            <dd><%= Current.organization_membership&.role || "—" %></dd>
          </div>
        </dl>
      <% else %>
        <%= render Ui::EmptyStateComponent.new(
              title: "No active organization",
              description: "Switch orgs in Clerk to load a workspace.") %>
      <% end %>
    <% end %>
  </div>

  <div>
    <%= button_to "Sign out", sign_out_path, method: :delete,
          class: "inline-flex items-center justify-center h-10 px-4 rounded-md border border-border text-fg hover:bg-surface-2 text-sm font-medium" %>
  </div>
</div>

<div class="max-w-3xl mx-auto py-8 px-4">
  <h1 class="text-2xl font-bold mb-4">Dashboard</h1>
  <dl class="space-y-1 text-sm">
    <dt class="font-semibold">Signed in as</dt>
    <dd><%= current_professional.email %></dd>

    <dt class="font-semibold mt-3">Role</dt>
    <dd><%= current_professional.role %></dd>

    <dt class="font-semibold mt-3">Clerk user id</dt>
    <dd class="font-mono"><%= current_professional.clerk_user_id %></dd>

    <dt class="font-semibold mt-3">Clerk org id</dt>
    <dd class="font-mono"><%= current_professional.clerk_org_id.presence || "—" %></dd>
  </dl>

  <%= button_to "Sign out", sign_out_path, method: :delete, class: "mt-6 underline" %>
</div>

<% content_for :page_title, "New API Token" %>

<div class="space-y-6 max-w-2xl">
  <header class="space-y-2">
    <h1 class="text-2xl font-semibold">Issue a personal access token</h1>
    <p class="text-sm text-fg-muted">Scopes follow a <code>resource:action</code> shape — e.g. <code>clients:read</code>, <code>messages:write</code>. A <code>write</code> scope implies the corresponding <code>read</code>.</p>
  </header>

  <%= simple_form_for @token, url: settings_personal_access_tokens_path do |f| %>
    <%= f.input :name, hint: "For your reference. e.g. 'CI deploy bot' or 'My agent'.", required: true %>
    <%= f.input :scopes, as: :string, hint: "Space- or comma-separated list of scopes (e.g. clients:read leads:write).", required: true %>
    <%= f.input :expires_at, as: :string, hint: "Optional ISO-8601 timestamp. Leave blank for a non-expiring token." %>

    <div class="pt-4 flex items-center gap-3">
      <%= f.submit "Create token",
            class: "inline-flex items-center justify-center h-10 px-4 rounded-md bg-primary text-on-primary text-sm font-medium" %>
      <%= link_to "Cancel", settings_personal_access_tokens_path,
            class: "text-sm text-fg-muted hover:text-fg" %>
    </div>
  <% end %>
</div>

<% content_for :page_title, "API Tokens" %>

<div class="space-y-6 max-w-4xl">
  <header class="flex items-start justify-between gap-4">
    <div>
      <h1 class="text-2xl font-semibold">Personal access tokens</h1>
      <p class="text-sm text-fg-muted">Programmatic access to <%= Current.organization&.name %> via the <code>/api/v1</code> and <code>/mcp</code> endpoints.</p>
    </div>
    <%= link_to "New token", new_settings_personal_access_token_path,
          class: "inline-flex items-center justify-center h-10 px-4 rounded-md bg-primary text-on-primary text-sm font-medium" %>
  </header>

  <% if flash[:plaintext_token].present? %>
    <%= render Ui::CardComponent.new(title: "Copy your new token now", subtitle: "This is the only time it will be displayed.") do %>
      <pre class="font-mono text-xs break-all whitespace-pre-wrap bg-surface-2 rounded p-3"><%= flash[:plaintext_token] %></pre>
    <% end %>
  <% end %>

  <%= render Ui::CardComponent.new(title: "Active & revoked tokens") do %>
    <% if @tokens.any? %>
      <ul class="divide-y divide-border">
        <% @tokens.each do |token| %>
          <li class="py-3 flex items-start justify-between gap-4">
            <div class="space-y-1">
              <div class="font-medium"><%= token.name %></div>
              <div class="text-xs text-fg-muted">
                Scopes: <code><%= token.scopes.join(", ").presence || "none" %></code>
              </div>
              <div class="text-xs text-fg-muted">
                Created <%= time_ago_in_words(token.created_at) %> ago
                <%= "· expires #{time_ago_in_words(token.expires_at)} from now" if token.expires_at %>
                <% if token.last_used_at %>· last used <%= time_ago_in_words(token.last_used_at) %> ago<% end %>
                <% if token.revoked? %>· <strong>revoked</strong><% end %>
              </div>
            </div>
            <% unless token.revoked? %>
              <%= button_to "Revoke", revoke_settings_personal_access_token_path(token),
                    method: :post,
                    data: { turbo_confirm: "Revoke this token? Any automations using it will stop working." },
                    class: "inline-flex items-center justify-center h-9 px-3 rounded-md border border-border text-sm text-fg hover:bg-surface-2" %>
            <% end %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <%= render Ui::EmptyStateComponent.new(
            title: "No tokens yet",
            description: "Issue a token to authenticate API calls as yourself.") %>
    <% end %>
  <% end %>
</div>

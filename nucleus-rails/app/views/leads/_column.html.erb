<%# One Kanban column. Header is the SortableJS handle for reordering
    stages themselves; the body is its own Sortable shared across columns
    via the "leads" group so cards can be dragged between columns. %>
<section class="flex h-full w-72 shrink-0 flex-col rounded-lg border border-border bg-surface"
         data-leads-pipeline-target="stage"
         data-stage-id="<%= stage.id %>"
         id="<%= dom_id(stage) %>">
  <header class="flex items-center justify-between gap-2 border-b border-border px-3 py-2 cursor-grab"
          data-leads-pipeline-target="stageHandle">
    <div class="flex min-w-0 items-center gap-2">
      <span class="size-2.5 shrink-0 rounded-full"
            style="background-color: <%= stage.color %>"></span>
      <p class="truncate text-sm font-medium"><%= stage.name %></p>
      <span class="text-xs text-fg-muted" data-leads-pipeline-target="count">
        <%= leads.size %>
      </span>
    </div>
    <button type="button"
            class="inline-flex items-center justify-center h-7 w-7 rounded-md hover:bg-surface-2 text-fg-muted text-lg leading-none"
            data-action="leads-pipeline#toggleQuickAdd"
            data-stage-id="<%= stage.id %>"
            aria-label="Add lead to <%= stage.name %>">+</button>
  </header>

  <div class="hidden border-b border-border p-2"
       data-leads-pipeline-target="quickAdd"
       data-stage-id="<%= stage.id %>">
    <%= form_with url: leads_path, method: :post, local: false,
                  data: { action: "turbo:submit-end->leads-pipeline#closeQuickAdd" },
                  class: "flex flex-col gap-1" do |f| %>
      <%= hidden_field_tag "lead[stage_id]", stage.id %>
      <%= text_field_tag "lead[full_name]", nil,
            placeholder: "Full name *",
            required: true,
            class: "h-8 rounded-md border border-border bg-surface-2 px-2 text-xs" %>
      <%= email_field_tag "lead[email]", nil,
            placeholder: "Email",
            class: "h-8 rounded-md border border-border bg-surface-2 px-2 text-xs" %>
      <%= text_field_tag "lead[phone]", nil,
            placeholder: "Phone",
            class: "h-8 rounded-md border border-border bg-surface-2 px-2 text-xs" %>
      <%= text_field_tag "lead[source]", nil,
            placeholder: "Source (referral, web…)",
            class: "h-8 rounded-md border border-border bg-surface-2 px-2 text-xs" %>
      <div class="flex items-center gap-2 justify-end">
        <button type="button" class="text-xs text-fg-muted"
                data-action="leads-pipeline#closeQuickAdd">Cancel</button>
        <%= f.submit "Add",
              class: "inline-flex items-center justify-center h-8 px-3 rounded-md bg-primary text-on-primary text-xs" %>
      </div>
    <% end %>
  </div>

  <ul class="flex flex-1 flex-col gap-2 overflow-y-auto p-2 min-h-32"
      id="lead_stage_<%= stage.id %>_leads"
      data-leads-pipeline-target="column"
      data-stage-id="<%= stage.id %>">
    <% leads.each do |lead| %>
      <%= render "leads/card", lead: lead, stage: stage %>
    <% end %>
    <% if leads.empty? %>
      <li class="px-2 py-6 text-center text-xs text-fg-muted pointer-events-none"
          data-leads-pipeline-target="emptyHint">
        Drop a lead here.
      </li>
    <% end %>
  </ul>
</section>

<% content_for :page_title, "Leads" %>

<%# Subscribe this page to the per-org leads stream so another tab's drag or
    stage edit flows in as a Turbo Stream. %>
<%= turbo_stream_from "organization", Current.organization.id, "leads" %>

<div class="space-y-6 max-w-full"
     data-controller="leads-pipeline"
     data-leads-pipeline-move-url-template-value="<%= move_lead_path(id: "__ID__") %>"
     data-leads-pipeline-reorder-url-value="<%= reorder_lead_stages_path %>">
  <header class="flex items-start justify-between gap-4">
    <div>
      <h1 class="text-2xl font-semibold">Leads</h1>
      <p class="text-sm text-fg-muted">
        <%= pluralize(@leads.size, "lead") %> across <%= pluralize(@stages.size, "stage") %>.
      </p>
    </div>
    <div class="flex items-center gap-2">
      <button type="button"
              class="inline-flex items-center justify-center h-10 px-4 rounded-md border border-border text-sm"
              data-action="leads-pipeline#openStageManager">
        Stages
      </button>
    </div>
  </header>

  <%# Kanban board. Each column is a Sortable list; the board container is
      its own Sortable with a "header" handle so stages can be reordered
      left-to-right by dragging the column header. %>
  <div class="flex w-full gap-3 overflow-x-auto pb-3"
       data-leads-pipeline-target="board">
    <% @stages.each do |stage| %>
      <%= render "leads/column",
            stage: stage,
            leads: @leads.select { |l| l.stage_id == stage.id } %>
    <% end %>
  </div>
</div>

<%# Detail panel. Empty frame by default; clicking a card replaces it. %>
<%= turbo_frame_tag "lead_detail" do %>
  <% if @open_lead %>
    <%= render "leads/detail",
          lead: @open_lead,
          stages: @stages,
          activities: @activities_by_lead[@open_lead.id] || [] %>
  <% end %>
<% end %>

<%# Stage manager modal — rendered once, toggled by the data-action above. %>
<%= render "lead_stages/manager", stages: @stages %>

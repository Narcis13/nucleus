<% content_for :page_title, "Tags" %>

<div class="space-y-6 max-w-4xl">
  <header class="flex items-start justify-between gap-4">
    <div>
      <h1 class="text-2xl font-semibold">Tags</h1>
      <p class="text-sm text-fg-muted">Shared labels for <%= Current.organization&.name %>.</p>
    </div>
    <%= link_to "New tag", new_tag_path,
          class: "inline-flex items-center justify-center h-10 px-4 rounded-md bg-primary text-on-primary text-sm font-medium" %>
  </header>

  <%= render Ui::CardComponent.new(title: "All tags") do %>
    <% if @tags.any? %>
      <ul class="divide-y divide-border">
        <% @tags.each do |tag| %>
          <li class="py-3 flex items-center justify-between gap-4">
            <div class="flex items-center gap-3">
              <span class="inline-block w-4 h-4 rounded" style="background-color: <%= tag.color %>"></span>
              <span class="font-medium"><%= tag.name %></span>
            </div>
            <div class="flex items-center gap-2">
              <%= link_to "Edit", edit_tag_path(tag), class: "text-xs text-fg-muted hover:text-fg" %>
              <%= button_to "Delete", tag_path(tag), method: :delete,
                    data: { turbo_confirm: "Delete tag #{tag.name}?" },
                    class: "text-xs text-danger hover:underline",
                    form: { class: "inline" } %>
            </div>
          </li>
        <% end %>
      </ul>
    <% else %>
      <%= render Ui::EmptyStateComponent.new(title: "No tags yet", description: "Create one to label clients.") %>
    <% end %>
  <% end %>
</div>

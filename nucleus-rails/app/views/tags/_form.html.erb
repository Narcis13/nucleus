<%= form_with model: tag, local: true, class: "space-y-4 max-w-md" do |f| %>
  <% if tag.errors.any? %>
    <div class="rounded-md border border-danger/40 bg-danger/10 p-3 text-sm text-danger">
      <ul class="list-disc pl-4">
        <% tag.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="flex flex-col gap-1">
    <%= f.label :name, class: "text-xs text-fg-muted" %>
    <%= f.text_field :name, required: true, class: "h-9 rounded-md border border-border bg-surface px-3 text-sm" %>
  </div>

  <div class="flex flex-col gap-1">
    <%= f.label :color, class: "text-xs text-fg-muted" %>
    <%= f.color_field :color, class: "h-9 w-24 rounded-md border border-border" %>
  </div>

  <div class="flex gap-3">
    <%= f.submit class: "inline-flex items-center justify-center h-10 px-4 rounded-md bg-primary text-on-primary text-sm font-medium" %>
    <%= link_to "Cancel", tags_path,
          class: "inline-flex items-center justify-center h-10 px-4 rounded-md border border-border text-sm" %>
  </div>
<% end %>

<%= form_with url: lead_stages_path, method: :post,
              class: "flex flex-col gap-2 rounded-md border border-dashed border-border p-3" do %>
  <label class="text-xs text-fg-muted">Add a stage</label>
  <div class="flex items-center gap-2">
    <input type="color" name="lead_stage[color]" value="#6366f1"
           aria-label="New stage color"
           class="h-8 w-9 cursor-pointer rounded border border-border bg-transparent p-0">
    <%= text_field_tag "lead_stage[name]", nil,
          placeholder: "Stage name",
          required: true,
          class: "h-9 flex-1 rounded-md border border-border bg-surface-2 px-2 text-sm" %>
  </div>
  <div class="flex items-center gap-4 pl-1 text-xs">
    <label class="flex items-center gap-1.5">
      <%= check_box_tag "lead_stage[is_won]", "1", false %>
      Won stage
    </label>
    <label class="flex items-center gap-1.5">
      <%= check_box_tag "lead_stage[is_lost]", "1", false %>
      Lost stage
    </label>
    <%= submit_tag "Add",
          class: "ml-auto inline-flex items-center justify-center h-8 px-3 rounded-md bg-primary text-on-primary text-xs" %>
  </div>
<% end %>

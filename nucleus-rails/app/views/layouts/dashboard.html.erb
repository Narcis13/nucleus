<!DOCTYPE html>
<html lang="en" data-controller="dark-mode" data-dark-mode-storage-key-value="nucleus.theme">
  <head>
    <title><%= content_for(:title) || "Nucleus" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <script>
      (function() {
        try {
          var t = localStorage.getItem("nucleus.theme");
          if (t === "dark" || (t === null && window.matchMedia("(prefers-color-scheme: dark)").matches)) {
            document.documentElement.classList.add("dark");
          }
        } catch (_) {}
      })();
    </script>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-bg text-fg antialiased">
    <div class="flex min-h-dvh">
      <aside class="hidden md:flex md:w-60 shrink-0 flex-col border-r border-border bg-surface">
        <div class="h-14 flex items-center px-5 border-b border-border">
          <%= link_to "Nucleus", dashboard_path, class: "font-semibold" %>
        </div>

        <nav class="flex-1 p-3 space-y-1 text-sm">
          <%= render "shared/nav_item", path: dashboard_path, label: "Dashboard", active: current_page?(dashboard_path) %>
          <%= render "shared/nav_item", path: clients_path,   label: "Clients",   active: controller_name == "clients" %>
          <%= render "shared/nav_item", path: leads_path,     label: "Leads",     active: %w[leads lead_stages lead_activities].include?(controller_name) %>
          <%= render "shared/nav_item", path: tags_path,      label: "Tags",      active: controller_name == "tags" %>
          <%# Future: services, calendar — wired in Rs7+ %>
        </nav>

        <div class="p-3 border-t border-border text-xs text-fg-muted">
          <% if current_professional %>
            <div class="truncate"><%= current_professional.email %></div>
            <div class="truncate"><%= current_professional.role %></div>
          <% end %>
        </div>
      </aside>

      <div class="flex-1 min-w-0 flex flex-col">
        <header class="h-14 flex items-center justify-between px-5 border-b border-border bg-surface">
          <div class="flex items-center gap-3">
            <button type="button"
                    class="md:hidden inline-flex h-9 w-9 items-center justify-center rounded-md border border-border"
                    aria-label="Toggle navigation">☰</button>
            <h1 class="text-sm text-fg-muted"><%= content_for(:page_title) || "Dashboard" %></h1>
          </div>

          <div class="flex items-center gap-3">
            <button type="button"
                    data-action="dark-mode#toggle"
                    class="inline-flex items-center justify-center h-9 w-9 rounded-md border border-border hover:bg-surface-2"
                    aria-label="Toggle theme">
              <span class="hidden dark:inline" aria-hidden="true">☀️</span>
              <span class="inline dark:hidden" aria-hidden="true">🌙</span>
            </button>
            <%= render "shared/clerk_islands" %>
          </div>
        </header>

        <%= render "shared/flash" %>

        <main class="flex-1 p-6">
          <%= turbo_frame_tag "main_content", target: "_top" do %>
            <%= yield %>
          <% end %>
        </main>
      </div>
    </div>

    <%# Live toast target — Rs8+ broadcasts Turbo streams here. %>
    <div id="toasts"
         class="pointer-events-none fixed inset-x-0 bottom-4 z-50 flex flex-col items-center gap-2 px-4"></div>
  </body>
</html>

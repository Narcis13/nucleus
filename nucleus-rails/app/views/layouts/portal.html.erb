<%# Client portal layout. Branded with the professional's colors via CSS
    custom properties set on <html>. Set in controllers with:
      @brand = { primary: "#...", surface: "#...", fg: "#..." }
    Unset keys fall back to app tokens. %>
<!DOCTYPE html>
<html lang="en" data-controller="dark-mode" data-dark-mode-storage-key-value="nucleus.portal.theme"
  <% if (brand = content_for?(:brand_style).presence) %>style="<%= brand %>"<% end %>>
  <head>
    <title><%= content_for(:title) || "Client Portal" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <script>
      (function() {
        try {
          var t = localStorage.getItem("nucleus.portal.theme");
          if (t === "dark") document.documentElement.classList.add("dark");
        } catch (_) {}
      })();
    </script>

    <%= yield :head %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-bg text-fg antialiased">
    <header class="border-b border-border bg-surface">
      <div class="max-w-4xl mx-auto px-5 py-3 flex items-center justify-between">
        <div class="flex items-center gap-3">
          <% if content_for?(:brand_logo) %><%= yield :brand_logo %><% end %>
          <span class="font-semibold"><%= content_for(:brand_name) || "Client Portal" %></span>
        </div>
        <div class="flex items-center gap-3">
          <%= yield :portal_nav %>
        </div>
      </div>
    </header>

    <%= render "shared/flash" %>

    <main class="max-w-4xl mx-auto px-5 py-8">
      <%= yield %>
    </main>

    <footer class="border-t border-border bg-surface mt-12">
      <div class="max-w-4xl mx-auto px-5 py-4 text-xs text-fg-muted flex justify-between">
        <span>Powered by Nucleus</span>
        <span><%= yield :portal_footer %></span>
      </div>
    </footer>
  </body>
</html>

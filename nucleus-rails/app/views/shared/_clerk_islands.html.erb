<%# Mounts Clerk's hosted UserButton + OrganizationSwitcher as client-side
    islands. Clerk's frontend SDK is loaded only for authenticated views. %>
<% if clerk_signed_in? && clerk_js_url %>
  <div class="flex items-center gap-3">
    <div id="clerk-org-switcher"></div>
    <div id="clerk-user-button"></div>
  </div>

  <script async crossorigin="anonymous"
          data-clerk-publishable-key="<%= ENV['CLERK_PUBLISHABLE_KEY'] %>"
          src="<%= clerk_js_url %>"
          type="text/javascript"></script>
  <script>
    window.addEventListener("load", async () => {
      if (typeof Clerk === "undefined") return;
      await Clerk.load();
      const org = document.getElementById("clerk-org-switcher");
      const ub  = document.getElementById("clerk-user-button");
      if (org) Clerk.mountOrganizationSwitcher(org);
      if (ub)  Clerk.mountUserButton(ub, { afterSignOutUrl: "<%= sign_in_path %>" });
    });
  </script>
<% end %>

<%# simple_form_for needs an object that responds to model_name.param_key —
    OpenStruct doesn't. A tiny ActiveModel::API struct gives the preview
    something to bind without dragging in a real AR model. %>
<% record_class = Class.new do
     include ActiveModel::Model
     attr_accessor :name, :email, :notes
     def self.name = "PreviewRecord"
   end %>
<% record = record_class.new(email: "", name: "", notes: "") %>
<%= simple_form_for record, url: "#", html: { class: "max-w-md space-y-4" } do |f| %>
  <%= render Ui::FormFieldComponent.new(form: f, attribute: :name,  label: "Full name", required: true) %>
  <%= render Ui::FormFieldComponent.new(form: f, attribute: :email, label: "Email",     hint: "We use this for invoices.") %>
  <%= render Ui::FormFieldComponent.new(form: f, attribute: :notes, as: :text, label: "Notes") %>
  <div class="flex justify-end">
    <%= render(Ui::ButtonComponent.new(type: "submit")) { "Save" } %>
  </div>
<% end %>

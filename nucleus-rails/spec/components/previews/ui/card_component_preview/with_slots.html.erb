<%= render Ui::CardComponent.new do |c| %>
  <% c.with_header do %>
    <div class="flex items-center justify-between">
      <h3 class="font-medium">Custom header</h3>
      <%= render(Ui::BadgeComponent.new(variant: :success)) { "Active" } %>
    </div>
  <% end %>

  <p>Body content goes here. Composing components should be frictionless.</p>

  <% c.with_footer do %>
    <div class="flex justify-end gap-2">
      <%= render Ui::ButtonComponent.new(variant: :ghost) do %>Cancel<% end %>
      <%= render Ui::ButtonComponent.new(variant: :primary) do %>Save<% end %>
    </div>
  <% end %>
<% end %>

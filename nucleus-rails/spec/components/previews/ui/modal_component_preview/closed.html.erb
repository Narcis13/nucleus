<div class="space-y-4">
  <button type="button"
          data-controller="modal"
          data-action="modal#open"
          data-modal-id-param="demo-modal"
          class="inline-flex h-10 px-4 items-center rounded-md bg-primary text-primary-fg">
    Open modal
  </button>

  <%= render Ui::ModalComponent.new(id: "demo-modal", title: "Confirm delete") do |m| %>
    <p class="text-sm">Are you sure you want to delete this client?</p>
    <% m.with_footer do %>
      <div class="flex justify-end gap-2">
        <%= render(Ui::ButtonComponent.new(variant: :ghost,        "data-action": "modal#close")) { "Cancel" } %>
        <%= render(Ui::ButtonComponent.new(variant: :destructive,  "data-action": "modal#close")) { "Delete" } %>
      </div>
    <% end %>
  <% end %>
</div>

source "https://rubygems.org"

# --- Rails core -------------------------------------------------------------
gem "rails", "~> 8.1.3"
gem "propshaft"
gem "pg", "~> 1.1"
gem "puma", ">= 5.0"
gem "importmap-rails"
gem "turbo-rails"
gem "stimulus-rails"
gem "tailwindcss-rails"
gem "tzinfo-data", platforms: %i[ windows jruby ]

# Rails 8 solid-trifecta (DB-backed cache, queue, cable)
gem "solid_cache"
gem "solid_queue"
gem "solid_cable"

gem "bootsnap", require: false
gem "kamal", require: false
gem "thruster", require: false

# --- From spike (carried forward) ------------------------------------------
gem "strong_migrations"

# Authentication
gem "clerk-sdk-ruby", require: "clerk"
gem "svix"

# Multi-tenancy
gem "acts_as_tenant"

# Subscriptions / billing (Pay 11 is current stable; plan's 8.0 pin is stale)
gem "pay", "~> 11.0"
gem "stripe", "~> 19.0"
gem "receipts", "~> 2.0"

# --- Rs1 additions ----------------------------------------------------------
# Authorization
gem "pundit"

# View layer
gem "view_component", "~> 4.0"
gem "phlex-rails"

# Pagination
gem "pagy", "~> 9.0"

# Forms
gem "simple_form"

# Search & filtering
gem "ransack"

# Email
gem "resend"
gem "mjml-rails"
gem "premailer-rails"

# PDF / images
gem "prawn", "~> 2.5"
gem "prawn-table"
gem "ferrum_pdf" # Rs1 plan named "chromic_pdf" (no such gem on rubygems); ferrum_pdf is the modern HTML→PDF via headless Chrome choice.
gem "image_processing", "~> 1.13"
gem "ruby-vips"

# Notifications
gem "noticed", "~> 2.6"

# iCal / scheduling
gem "icalendar"
gem "ice_cube"

# Web push
gem "web-push"

# CSV (stdlib gemified in Ruby 3.4+)
gem "csv"

# Observability
gem "sentry-ruby"
gem "sentry-rails"
gem "ahoy_matey"

# Rate limiting
gem "rack-attack"

# --- Rs4.5 additions --------------------------------------------------------
# JSON serialization for the /api/v1 layer. Faster + simpler than Jbuilder;
# resource classes live in app/resources/.
gem "alba"

# PAT hashing. Tokens are stored as a bcrypt digest; the plaintext is shown
# to the user exactly once at issue time.
gem "bcrypt", "~> 3.1"

# Security
gem "rack-cors"
gem "secure_headers"

# Git hooks
gem "lefthook", require: false


# -----------------------------------------------------------------------------
# Nucleus (Rails) — development environment template.
#
# Copy to `.env.development` (bin/setup does this automatically) and fill in
# real values. Never commit the filled copy.
# -----------------------------------------------------------------------------

# --- Database ----------------------------------------------------------------
# Supabase Postgres URL. Use the pooler hostname with sslmode=require.
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-REGION.pooler.supabase.com:5432/postgres?sslmode=require

# Separate test DB. Known Rs1 debt: the spike shared dev+test; set a local
# Postgres test DB here so Minitest/RSpec can run tenancy isolation checks.
# TEST_DATABASE_URL=postgresql://localhost/nucleus_test

# --- Clerk (auth) ------------------------------------------------------------
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
# Created in the Clerk dashboard → Webhooks → add endpoint. Starts with whsec_.
CLERK_WEBHOOK_SECRET=whsec_...
CLERK_SIGN_IN_URL=/sign-in
CLERK_AFTER_SIGN_IN_URL=/dashboard

# --- Stripe (billing via Pay gem) -------------------------------------------
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
# `stripe listen` prints this when you forward webhooks locally.
STRIPE_WEBHOOK_SECRET=whsec_...

# Recurring monthly prices (EUR) — test mode price IDs from the Stripe dashboard.
STRIPE_STARTER_PRICE=price_...
STRIPE_GROWTH_PRICE=price_...
STRIPE_PRO_PRICE=price_...

# --- Email (Resend + MJML) ---------------------------------------------------
RESEND_API_KEY=re_...
MAIL_FROM=nucleus@example.com

# --- Observability (Sentry) --------------------------------------------------
SENTRY_DSN=

# --- Web Push (VAPID) --------------------------------------------------------
# Generate with: `bundle exec rake push:vapid_keys` (added in a later session),
# or via `WebPush.generate_key` in a console.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:ops@example.com

# --- Rails internals ---------------------------------------------------------
# Supabase app role used by the RLS-aware connection path. See CLAUDE.md —
# the default `postgres` role has BYPASSRLS and silently ignores policies.
SUPABASE_APP_ROLE=authenticated

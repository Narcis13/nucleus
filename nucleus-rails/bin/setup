#!/usr/bin/env ruby
require "fileutils"

APP_ROOT = File.expand_path("..", __dir__)

def system!(*args)
  system(*args, exception: true)
end

FileUtils.chdir APP_ROOT do
  puts "== Installing dependencies =="
  system("bundle check") || system!("bundle install")

  puts "\n== Bootstrapping .env.development =="
  freshly_copied = false
  if File.exist?(".env.development")
    puts "   .env.development already present."
  elsif File.exist?(".env.development.example")
    FileUtils.cp ".env.development.example", ".env.development"
    freshly_copied = true
    puts "   Created .env.development from .env.development.example."
  else
    puts "   (no .env.development.example found — skipping)"
  end

  puts "\n== Installing git hooks (lefthook) =="
  # lefthook config lives at the monorepo root (../lefthook.yml) so hooks
  # install into the parent nucleus/.git repo.
  Dir.chdir("..") { system! "bundle exec --gemfile=nucleus-rails/Gemfile lefthook install -f" }

  if freshly_copied
    puts "\n== First-run: fill in .env.development and re-run bin/setup =="
    puts "   DATABASE_URL, Clerk, Stripe, and Resend keys all need real values."
    exit 0
  end

  puts "\n== Preparing database =="
  system! "bin/rails db:prepare"
  system! "bin/rails db:reset" if ARGV.include?("--reset")

  puts "\n== Removing old logs and tempfiles =="
  system! "bin/rails log:clear tmp:clear"

  unless ARGV.include?("--skip-server")
    puts "\n== Starting development server =="
    STDOUT.flush
    exec "bin/dev"
  end
end
